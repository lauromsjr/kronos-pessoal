{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/app.ts",
    "src/database/sqlite.ts",
    "src/modules/auth/**/*.ts",
    "src/modules/cron/**/*.ts",
    "src/modules/tasks/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
