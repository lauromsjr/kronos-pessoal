# Kronos — Variáveis de Ambiente
# Copiar este arquivo para .env e preencher os valores

# ============================================
# SERVIDOR
# ============================================
PORT=3002
NODE_ENV=production

# ============================================
# ANTHROPIC — OBRIGATÓRIO
# ============================================
# A chave da API Anthropic (necesária para Claude funcionar)
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# PostgreSQL — Banco de dados do Kronos
# ============================================
# Formato: postgresql://usuario:senha@host:porta/banco
# Exemplo: postgresql://kronos_user:senha_forte@kronos-db:5432/kronos
DATABASE_URL=postgresql://user:password@host:5432/kronos

# ============================================
# EVOLUTION API — WhatsApp (instância kronos)
# ============================================
# URL da instância Evolution API (porta padrão: 8080)
# Exemplo: http://evolution-api:8080 (se rodando no mesmo painel)
EVOLUTION_API_URL=http://evolution-api:8080

# Chave de autenticação da instância Evolution
EVOLUTION_API_KEY=

# Nome da instância dentro da Evolution API
EVOLUTION_INSTANCE=kronos

# ============================================
# PlugAI API — Consumo de dados de negócio
# ============================================
# URL da API PlugAI (apenas leitura de dados)
PLUGAI_API_URL=https://api.plugaimarketing.com

# JWT com permissão de viewer na organização
# Obtém em: PlugAI → Configurações → Integrações → Gerar JWT
PLUGAI_JWT=

# ============================================
# GOOGLE CLOUD — Drive e Google Calendar
# ============================================
# JSON da service account codificado em base64 ou como string
# Obtém em: Google Cloud Console → Service Accounts → Criar chave JSON
GOOGLE_SERVICE_ACCOUNT_JSON=

# ID da pasta no Google Drive onde salvar documentos do Kronos
# Criar pasta "Kronos" no Drive e pegar o ID da URL
GOOGLE_DRIVE_FOLDER_ID=

# ============================================
# GOOGLE CALENDAR — OAuth
# ============================================
# Escopo usado pelo Kronos: https://www.googleapis.com/auth/calendar.events
# Reautorize em Configurações > Google Agenda ao mudar de somente leitura para escrita.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://kronos.plugaimarketing.com/api/calendar/oauth/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_OAUTH_TOKEN_PATH=/app/data/google_calendar_token.json

# ============================================
# SEGURANÇA — Whitelist Lauro
# ============================================
# Telefone do Lauro (apenas este número consegue usar o Kronos)
# Formato: 55 + DDD + número (sem caracteres especiais)
# Exemplo: 5562998441163
LAURO_PHONE=55XXXXXXXXXXX

# ============================================
# KRONOS TASKS — SQLite e API Key
# ============================================
KRONOS_API_KEY=change-me
SQLITE_PATH=/app/data/kronos.sqlite

# ============================================
# KRONOS AUTH — Login web
# ============================================
KRONOS_AUTH_USERNAME=lauro
KRONOS_AUTH_PASSWORD_HASH=
KRONOS_SESSION_SECRET=change-me-session-secret
KRONOS_SESSION_DAYS=30

# ============================================
# OPENAI — Sugestões de prioridades com IA
# ============================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
